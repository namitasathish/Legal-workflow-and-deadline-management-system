{
  "name": "indian-judicial-system-backend",
  "version": "1.0.0",
  "description": "Backend for Indian Judicial System - Case Tracking & Anonymous Filing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint . --ext .js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch"
  },
  "keywords": ["judicial", "case-tracking", "anonymous-filing", "devops"],
  "author": "University Students - DevOps Demo",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "models/**/*.js",
      "server.js"
    ]
  }
}
